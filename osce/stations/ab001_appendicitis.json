  "management": {
    "immediate": [
      "NPO (nothing by mouth) - prepare for possible surgery",
      "IV fluids (normal saline or Ringer's lactate) for hydration",
      "Analgesia (Morphine 2-4mg IV titrated to effect)",
      "Antiemetics (Ondansetron 4mg IV) for nausea",
      "IV antibiotics (Cefoxitin or Cefazolin + Metronidazole) pre-operatively",
      "Urgent surgical consultation for laparoscopic appendectomy"
    ],
    "monitoring": [
      "Vital signs every 2-4 hours",
      "Pain reassessment after analgesia",
      "Monitor for signs of perforation (worsening pain, peritonitis)",
      "Pre-operative checklist"
    ],
    "longTerm": [
      "Laparoscopic appendectomy within 24 hours",
      "Post-operative antibiotics if complicated (perforated/gangrenous)",
      "Early mobilization post-surgery",
      "Follow-up in surgical clinic in 2 weeks",
      "Return to normal activities in 1-2 weeks (laparoscopic)"
    ]
  },
