  "management": {
    "immediate": [
      "Activate cath lab / cardiology team",
      "Aspirin 300mg PO (chewed)",
      "Ticagrelor 180mg PO loading dose",
      "Morphine 2-4mg IV for pain",
      "Oxygen if SpO2 <90%",
      "Nitroglycerin SL if ongoing pain and no hypotension",
      "Heparin/Enoxaparin per protocol",
      "Primary PCI within 90 minutes"
    ],
    "monitoring": [
      "Continuous cardiac monitoring",
      "Serial ECGs",
      "Repeat troponin at 3-6 hours",
      "Vital signs every 15 minutes"
    ],
    "longTerm": [
      "Dual antiplatelet therapy (DAPT) for 12 months",
      "High-intensity statin (Atorvastatin 80mg)",
      "Beta-blocker (Metoprolol)",
      "ACE inhibitor (Lisinopril)",
      "Cardiac rehabilitation referral",
      "Smoking cessation counseling",
      "Lifestyle modifications"
    ]
  },
